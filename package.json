{
  "name": "0223wechat-server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:init": "tsx scripts/init-db.ts",
    "migrate:reservation-unique": "tsx scripts/db_migrate_reservation_unique.ts",
    "migrate:core": "tsx scripts/db_migrate_core_constraints.ts",
    "migrate:error-log": "tsx scripts/db_migrate_error_log.ts",
    "migrate:message-task": "tsx scripts/db_migrate_message_task.ts",
    "migrate:all": "npm run migrate:reservation-unique && npm run migrate:core && npm run migrate:error-log && npm run migrate:message-task"
  },
  "dependencies": {
    "@alicloud/dysmsapi20170525": "^4.5.0",
    "@alicloud/openapi-client": "^0.4.15",
    "@hono/node-server": "^1.19.9",
    "adm-zip": "^0.5.16",
    "ali-oss": "^6.23.0",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "form-data": "^4.0.5",
    "hono": "^4.12.1",
    "multer": "^2.1.1",
    "mysql2": "^3.17.4",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/ali-oss": "^6.23.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.37",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
