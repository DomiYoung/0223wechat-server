<div class="m-mask-box bgw js-tip" style="display: none;">
    <div class="m-tip js-tip-txt"></div>
</div>
<div class="register-popup">
    <div class="register-cont-wrap">
        <!--注册窗-->
        <div class="reg-details-wrap">
            <div class="reg-details-t g-flex i-al">
                <span class="reg-details-t-com col2 k-fs46">免费预约试用</span>
            </div>
            <form id="regForm" class="reg-details-com">
                <div class="reg-num-wrap g-flex reg-bc  f-oh g-mb30" id="reg-num-wrap">
                    <select id="zone" class="reg-select k-fs30 col2" name="zone">
                        <option value="0086">中国大陆(86)</option>
                        <option value="00886">中国台湾(886)</option>
                        <option value="00852">中国香港(852)</option>
                        <option value="00853">中国澳门(853)</option>
                    </select>
                    <input type="number" id="phone" name="phone" class="reg-details-phone k-fs30"  maxlength="11" placeholder="手机号"/>
                </div>
                <p class="reg-details-code reg-wh g-mb30">
                    <input type="number" name="code" id="code" maxlength="4" class="reg-details-coder reg-wh2 k-fs30 reg-pl reg-bc g-rmA reg-bc " placeholder="请填写短信验证码">
                    <input type="button" id="getCode" class="reg-btn-coder reg-bc g-rmA reg-h col2 k-fs30 reg-wh3" value="获取验证码"/>

                </p>
                <p class="f-pr g-mb30">
                    <span style="position:absolute;left:0;right: 0;top:0;bottom: 0;" class="js-area-trg"></span>
                    <input type="text" id="address" name="address" readonly="readonly"
                    class="reg-details-add reg-bc reg-pl reg-wh k-fs30 g-rmA" placeholder="请选择省 / 市 / 区">
                    <span class="f-pa register-errow"></span>
                </p>

                <input type="button" id="formSubmit" class="reg-btn-com k-fs36" value="提交">
                <input type="hidden" name="province" id="province" value=""/>
                <input type="hidden" name="city" id="city" value=""/>
                <input type="hidden" name="region" id="region" value=""/>
                <input type="hidden" name="provinceName" id="provinceName" value=""/>
                <input type="hidden" name="cityName" id="cityName" value=""/>
                <input type="hidden" name="regionName" id="regionName" value=""/>
                <input type="hidden" name="solutionId" id="solutionId" value="32"/>
            </form>
        </div>
        <!--关闭按钮-->
        <div class="m-box-close-btn js-box-close">
            <img class="" src="/img/home/close.png">
        </div>
    </div>
</div>
<!--提示信息-->
