    <div class="wds-7f-dei-wrap">
        <div class="wds-7f-dei g-flex g-mb90 i-al">
            <div class="wz-4f-img wz-fwzd"></div>
            <p class="flex1">
                <span>服务指导</span>
                <span class="wds-texts g-mt10">一对一客服在线产品上手培训</span>
            </p>
        </div>
        <div class="wds-7f-dei g-flex g-mb90  i-al">
            <div class="wz-4f-img wz-yypx"></div>
            <p class="flex1">
                <span>运营培训</span>
