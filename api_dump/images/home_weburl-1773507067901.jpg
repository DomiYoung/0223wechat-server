<script type="text/javascript" src="/build/js/swiper-c5abbf38cb.js"></script>
<script type="text/javascript">
    var swiperLists = ["#sw-meet1"];
    $(function () {
        // 初始化 swiper
        for (var i in swiperLists) {
            new Swiper(swiperLists[i], {
                slidesPerView: 'auto',
                freeMode: true
            })
        }
    });
</script>
